---
// welcome.astro — post-payment confirmation page. Stripe Payment Links redirect
// here after a successful subscription. Sets expectations before the first
// onboarding email lands. noindex: this is a transactional page, not for search.
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  {
    n: '01',
    title: 'A receipt is on its way',
    body: "Stripe has emailed you a receipt for your first payment, with the plan and amount. That's your confirmation, keep it for your records.",
  },
  {
    n: '02',
    title: 'I set up your account',
    body: "Your site is now in my hands. I get you booked into the care plan, set up monitoring, and make sure everything I need is in place to look after it properly.",
  },
  {
    n: '03',
    title: 'We have a quick kickoff call',
    body: "I'll email you a link to grab a time that suits. A short call to walk through your site, sort access securely, and hear what matters most to you.",
  },
];
---
<BaseLayout
  title="Welcome to WP Base — You're all set"
  description="Your WP Base care plan is active. Here's what happens next."
>
  <section class="welcome-hero-section">
    <div class="welcome-inner">
      <div class="welcome-badge" aria-hidden="true">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="15" stroke="var(--accent)" stroke-width="2"/>
          <path d="M10 16.5l4 4 8-9" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="section-label">Payment received</span>
      <h1 class="welcome-headline">
        You're in.<br />
        <span class="accent">Welcome to WP Base</span>
      </h1>
      <p class="welcome-lead">
        Thanks for signing up. Your payment has gone through and your care plan is
        active. There's nothing else you need to do right now, but here's exactly
        what happens next so you know what to expect.
      </p>
    </div>
  </section>

  <section class="welcome-steps-section">
    <div class="welcome-inner">
      <div class="welcome-grid">
        {steps.map((step) => (
          <div class="welcome-card">
            <span class="welcome-card-num">{step.n}</span>
            <h2>{step.title}</h2>
            <p>{step.body}</p>
          </div>
        ))}
      </div>

      <div class="welcome-footer">
        <p>
          Keep an eye on your inbox over the next day or two. If you need anything
          in the meantime, or your receipt hasn't arrived, just email
          <a href="mailto:hello@wpbase.co.uk">hello@wpbase.co.uk</a> and I'll sort it.
        </p>
        <a href="/" class="welcome-home-link">Back to the homepage</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .welcome-hero-section {
    padding: 8rem 1.5rem 3rem;
    background: var(--midnight);
    color: var(--snow);
    text-align: center;
  }
  .welcome-inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .welcome-badge {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem;
  }
  .welcome-badge svg {
    width: 100%;
    height: 100%;
  }
  .welcome-hero-section .section-label {
    color: var(--text-light);
  }
  .welcome-headline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.08;
    margin: 1rem 0 1.5rem;
  }
  .welcome-headline .accent {
    color: var(--accent);
  }
  .welcome-lead {
    font-family: 'Epilogue', sans-serif;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.6;
    max-width: 620px;
    margin: 0 auto;
    opacity: 0.9;
  }

  .welcome-steps-section {
    padding: 4rem 1.5rem;
  }
  .welcome-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .welcome-card {
    padding: 2rem 1.75rem;
    border: 1px solid rgba(8, 16, 28, 0.1);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.4);
  }
  .welcome-card-num {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--accent-ink, var(--midnight));
    background: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 10px;
    margin-bottom: 1.25rem;
  }
  .welcome-card h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 1.25rem;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }
  .welcome-card p {
    font-family: 'Epilogue', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.85;
  }

  .welcome-footer {
    max-width: 620px;
    margin: 3rem auto 0;
    text-align: center;
  }
  .welcome-footer p {
    font-family: 'Epilogue', sans-serif;
    font-size: 1.05rem;
    line-height: 1.7;
    opacity: 0.85;
    margin: 0 0 1.5rem;
  }
  .welcome-footer a {
    color: var(--midnight);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 2px;
  }
  .welcome-home-link {
    display: inline-block;
    margin-top: 0.5rem;
  }

  @media (max-width: 820px) {
    .welcome-grid {
      grid-template-columns: 1fr;
    }
    .welcome-hero-section {
      padding-top: 6.5rem;
    }
  }
</style>
