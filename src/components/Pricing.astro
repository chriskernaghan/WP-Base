---
// Pricing.astro — three tiers plus custom card, monthly/annual toggle, condensed layout.
// Annual = 10 months' price (two months free), shown as monthly equivalent.
// CTAs link to Stripe Payment Links; the billing toggle swaps both price and href.
const tiers = [
  {
    tier: 'Silver',
    monthly: 99,
    annualMonthly: 82,
    annualTotal: 990,
    hours: '5 hours included',
    featured: false,
    monthlyUrl: 'https://buy.stripe.com/14A6oG6ll1uu6eI0Gf1ZS00',
    annualUrl: 'https://buy.stripe.com/8x2dR8aBB1uugTmex51ZS01',
    features: [
      'Core, plugin & theme updates',
      'Daily backups',
      'Uptime monitoring',
      'Monthly report',
    ],
  },
  {
    tier: 'Gold',
    monthly: 169,
    annualMonthly: 140,
    annualTotal: 1690,
    hours: '10 hours included',
    featured: true,
    monthlyUrl: 'https://buy.stripe.com/14A5kCaBBgpo5aEdt11ZS02',
    annualUrl: 'https://buy.stripe.com/3cIbJ0dNN0qq5aE4Wv1ZS03',
    features: [
      'Everything in Silver',
      'Performance optimisation',
      'Security scanning',
      'Bug fixes & support',
      'Priority response',
    ],
  },
  {
    tier: 'Platinum',
    monthly: 239,
    annualMonthly: 199,
    annualTotal: 2390,
    hours: '15 hours included',
    featured: false,
    monthlyUrl: 'https://buy.stripe.com/28EfZg8tt4GGdHadt11ZS04',
    annualUrl: 'https://buy.stripe.com/14AcN43990qqfPifB91ZS05',
    features: [
      'Everything in Gold',
      'Content updates',
      'Database optimisation',
      'Dedicated support',
      'Same-day response',
    ],
  },
];
---
<section id="pricing" class="pricing">
  <div class="section-header">
    <span class="section-label">Pricing</span>
    <h2>Simple, Transparent Pricing</h2>
    <p>No surprises, no hidden fees, just reliable WordPress care at a fixed monthly rate</p>
  </div>
  <div class="billing-toggle" role="group" aria-label="Billing period">
    <button type="button" class="billing-option is-active" data-billing="monthly" aria-pressed="true">Monthly</button>
    <button type="button" class="billing-option" data-billing="annual" aria-pressed="false">
      Annual <span class="billing-badge">2 months free</span>
    </button>
  </div>
  <div class="pricing-grid" data-billing-mode="monthly">
    {tiers.map((tier) => (
      <div class={`pricing-card${tier.featured ? ' featured' : ''}`}>
        {tier.featured && <div class="featured-label">Most Popular</div>}
        <div class="pricing-tier">{tier.tier}</div>
        <div class="pricing-price">
          <sup>£</sup><span class="price-value" data-monthly={tier.monthly} data-annual={tier.annualMonthly}>{tier.monthly}</span>
          <span class="price-period">/month</span>
        </div>
        <div class="pricing-billed">billed annually (£{tier.annualTotal.toLocaleString('en-GB')})</div>
        <div class="pricing-hours">⏱ {tier.hours}</div>
        <div class="pricing-divider"></div>
        <ul class="pricing-features">
          {tier.features.map((f) => <li>{f}</li>)}
        </ul>
        <a href={tier.monthlyUrl} class="pricing-cta" data-monthly-url={tier.monthlyUrl} data-annual-url={tier.annualUrl}>Get Started</a>
      </div>
    ))}
    <div class="pricing-card pricing-custom">
      <div class="pricing-tier">Custom</div>
      <h3>Need something bespoke?</h3>
      <p>Flexible retainers for agencies and businesses with specific requirements.</p>
      <a href="#contact" class="pricing-cta">Let's Talk</a>
    </div>
  </div>
</section>
<script>
  document.querySelectorAll('.billing-toggle').forEach((toggle) => {
    const grid = toggle.parentElement?.querySelector('.pricing-grid');
    if (!grid) return;
    toggle.querySelectorAll('.billing-option').forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.getAttribute('data-billing');
        if (!mode || btn.classList.contains('is-active')) return;
        toggle.querySelectorAll('.billing-option').forEach((b) => {
          const active = b === btn;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-pressed', String(active));
        });
        grid.setAttribute('data-billing-mode', mode);
        grid.querySelectorAll('.price-value').forEach((el) => {
          const value = el.getAttribute(mode === 'annual' ? 'data-annual' : 'data-monthly');
          if (value) el.textContent = value;
        });
        grid.querySelectorAll('.pricing-cta[data-monthly-url]').forEach((el) => {
          const url = el.getAttribute(mode === 'annual' ? 'data-annual-url' : 'data-monthly-url');
          if (url) el.setAttribute('href', url);
        });
      });
    });
  });
</script>
