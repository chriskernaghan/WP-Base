<div class="mobile-menu-backdrop" id="mobileMenuBackdrop"></div>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  const mobileMenuBackdrop = document.getElementById('mobileMenuBackdrop');
  const servicesToggle = document.getElementById('mobileServicesToggle');
  const servicesAccordion = document.getElementById('mobileServicesAccordion');

  function closeMobileMenu() {
    hamburger?.classList.remove('open');
    mobileMenu?.classList.remove('open');
    mobileMenuBackdrop?.classList.remove('open');
  }

  // Pin the menu directly below the nav's real bottom edge. The nav's height
  // varies (mobile padding, scroll state), so a hardcoded CSS top clips the
  // first menu item. Measure it instead.
  function positionMobileMenu() {
    const navEl = document.querySelector('nav');
    if (!navEl || !mobileMenu) return;
    const navBottom = Math.round(navEl.getBoundingClientRect().bottom);
    mobileMenu.style.top = navBottom + 'px';
    mobileMenu.style.maxHeight = `calc(100vh - ${navBottom}px)`;
    if (mobileMenuBackdrop) {
      mobileMenuBackdrop.style.top = navBottom + 'px';
      mobileMenuBackdrop.style.height = `calc(100vh - ${navBottom}px)`;
    }
  }

  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      positionMobileMenu();
      hamburger.classList.toggle('open');
      mobileMenu.classList.toggle('open');
      mobileMenuBackdrop?.classList.toggle('open');
    });

    window.addEventListener('resize', () => {
      if (mobileMenu.classList.contains('open')) positionMobileMenu();
    });

    // Close the menu when a real navigation link is tapped, but NOT when the
    // Services accordion toggle is tapped (that just expands sub-items).
    document.querySelectorAll('.mobile-menu a, .nav-links a').forEach((link) => {
      link.addEventListener('click', closeMobileMenu);
    });

    mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);
  }

  // Mobile Services accordion: tap to expand/collapse.
  if (servicesToggle && servicesAccordion) {
    servicesToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = servicesAccordion.classList.toggle('open');
      servicesToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  }

  // Smooth scroll for on-page anchor links from the homepage
  document.querySelectorAll('a[href^="/#"]').forEach((link) => {
    link.addEventListener('click', (e) => {
      if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href.replace('/', ''));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      }
    });
  });
</script>
