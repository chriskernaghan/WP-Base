---
// Hero.astro — top of the homepage. Rating pill, headline, description, stats, CTAs, terminal feed.
// Terminal animation initialises from the homepage script.
---

<section class="hero-v2">
  <div class="hero-v2-inner">
    <div class="hero-v2-top">
      <div class="hero-v2-left">
        <a href="https://share.google/HmqVC5OhdKakcRtS4" target="_blank" rel="noopener" class="hero-v2-rating">
          <span class="hero-v2-rating-stars" aria-hidden="true">★★★★★</span>
          <span class="hero-v2-rating-text"><strong>5.0</strong> on Google · clients love working with us</span>
        </a>
        <h1 class="hero-v2-headline">
          WordPress care<br />
          <span class="accent">without the<br />agency price</span>
        </h1>
        <p class="hero-v2-desc">
          Maintenance, updates, backups and security handled for a fixed monthly
          fee, by one person you can actually get on the phone.
        </p>
        <!--<ul class="hero-v2-stats">
          <li><span class="stat-tick" aria-hidden="true">✓</span><strong>4 years</strong> avg. client relationship</li>
          <li><span class="stat-tick" aria-hidden="true">✓</span><strong>&lt;1 hour</strong> response time</li>
          <li><span class="stat-tick" aria-hidden="true">✓</span><strong>0</strong> security breaches</li>
          <li><span class="stat-tick" aria-hidden="true">✓</span><strong>NI</strong> based &amp; direct access</li>
        </ul>-->
        <div class="hero-v2-cta-row">
          <a href="#contact" class="hero-v2-cta-primary">
            Get Your Free Audit
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="#clients" class="hero-v2-cta-secondary">See our work</a>
        </div>
      </div>

      <div class="hero-terminal" aria-hidden="true">
        <div class="hero-terminal-bar">
          <div class="hero-terminal-dots">
            <span></span><span></span><span></span>
          </div>
          <div class="hero-terminal-status">
            <span class="hero-terminal-pulse"></span>
            <span class="hero-terminal-status-text">All systems operational</span>
          </div>
          <div class="hero-terminal-clock" id="hero-terminal-clock">--:--:--</div>
        </div>
        <div class="hero-terminal-feed" id="hero-terminal-feed"></div>
      </div>
    </div>
  </div>
</section>
